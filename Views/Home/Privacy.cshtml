@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="text-center mb-5">
                <div class="fs-1 mb-2">🛡️</div>
                <h1 class="fw-bold text-primary display-6 mb-3">@ViewData["Title"]</h1>
                <p class="lead text-muted mx-auto" style="max-width: 600px;">Your privacy is important to us. This policy outlines how we handle your data.</p>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0 rounded-4 hover-lift p-2">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                    <i class="fs-4">📊</i>
                                </div>
                                <h5 class="card-title fw-bold mb-0">Information Collected</h5>
                            </div>
                            <p class="card-text text-muted">We collect account details (email, login) and expense data (amount, category, notes, date).</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0 rounded-4 hover-lift p-2">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-success bg-opacity-10 text-success rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                    <i class="fs-4">💡</i>
                                </div>
                                <h5 class="card-title fw-bold mb-0">Use of Information</h5>
                            </div>
                            <p class="card-text text-muted">Data is used only to provide expense tracking, analytics, and budgeting features.</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0 rounded-4 hover-lift p-2">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-warning bg-opacity-10 text-warning rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                    <i class="fs-4">🔒</i>
                                </div>
                                <h5 class="card-title fw-bold mb-0">Data Security</h5>
                            </div>
                            <p class="card-text text-muted">All information is stored securely and protected against unauthorized access.</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0 rounded-4 hover-lift p-2">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-info bg-opacity-10 text-info rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                    <i class="fs-4">🙋‍♀️</i>
                                </div>
                                <h5 class="card-title fw-bold mb-0">User Rights</h5>
                            </div>
                            <p class="card-text text-muted">You may request to view, update, or delete your data at any time.</p>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0 rounded-4 hover-lift p-2">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                    <i class="fs-4">🍪</i>
                                </div>
                                <h5 class="card-title fw-bold mb-0">Cookies</h5>
                            </div>
                            <p class="card-text text-muted">Session cookies are used for authentication and navigation.</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card h-100 shadow-sm border-0 rounded-4 hover-lift p-2">
                        <div class="card-body">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-danger bg-opacity-10 text-danger rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                    <i class="fs-4">📧</i>
                                </div>
                                <h5 class="card-title fw-bold mb-0">Contact</h5>
                            </div>
                            <p class="card-text text-muted">For privacy concerns, please reach out via <a href="mailto:expensetracker201918@gmail.com" class="fw-semibold text-decoration-none">expensetracker201918@gmail.com</a>.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
