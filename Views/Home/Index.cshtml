@{
    ViewData["Title"] = "Dashboard";
    
    // Setup for month dropdown
    var months = new[] { "January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December" };
}

<div class="row mb-4 mt-3">
    <div class="col-md-12 text-center">
        <h1 class="display-4 fw-bold text-primary">Expense Dashboard</h1>
        <p class="lead text-muted">Track and analyze your spending</p>
    </div>
</div>

<!-- FILTER BAR -->
<div class="card shadow-sm border-0 rounded-4 mb-4">
    <div class="card-body p-3">
        <form method="get" asp-action="Index" class="d-flex justify-content-center align-items-center gap-3 flex-wrap m-0">
            <div class="d-flex align-items-center">
                <label for="monthFilter" class="fw-bold text-muted me-2 mb-0 small text-uppercase tracking-wider">Month</label>
                <select id="monthFilter" name="month" class="form-select form-select-sm border-0 bg-light rounded-pill px-3 py-2 fw-semibold" style="width: 140px; box-shadow: none;">
                    @for (int i = 1; i <= 12; i++)
                    {
                        var isSelected = ViewBag.SelectedMonth == i ? "selected" : "";
                        <!option value="@i" @isSelected>@months[i - 1]</!option>
                    }
                </select>
            </div>
            <div class="d-flex align-items-center">
                <label for="yearFilter" class="fw-bold text-muted me-2 mb-0 small text-uppercase tracking-wider">Year</label>
                <select id="yearFilter" name="year" class="form-select form-select-sm border-0 bg-light rounded-pill px-3 py-2 fw-semibold" style="width: 140px; box-shadow: none;">
                    @foreach (var year in ViewBag.AvailableYears)
                    {
                        var isSelectedYear = ViewBag.SelectedYear == year ? "selected" : "";
                        <!option value="@year" @isSelectedYear>@year</!option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-primary btn-sm px-4 py-2 rounded-pill fw-bold shadow-sm">Apply Filter</button>
        </form>
    </div>
</div>

<!-- SUMMARY CARDS -->
<div class="row mb-4 g-4">
    <div class="col-md-4">
        <div class="card text-white h-100 shadow-sm border-0 rounded-4 hover-lift" style="background: linear-gradient(135deg, var(--primary-hover), var(--primary-color));">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-white-50 small fw-bold text-uppercase mb-2 tracking-wider">Total Expenses</div>
                        <div class="display-6 fw-bold mb-0" style="letter-spacing: -1px;">@ViewBag.TotalExpenses.ToString("C")</div>
                    </div>
                    <div class="fs-1 opacity-50 bg-white bg-opacity-10 rounded-circle p-3 d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">💰</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white h-100 shadow-sm border-0 rounded-4 hover-lift" style="background: linear-gradient(135deg, #059669, #10b981);">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-white-50 small fw-bold text-uppercase mb-2 tracking-wider">Top Category</div>
                        <div class="h3 fw-bold mb-0 text-truncate" style="max-width: 150px;">@ViewBag.TopCategory</div>
                    </div>
                    <div class="fs-1 opacity-50 bg-white bg-opacity-10 rounded-circle p-3 d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">🏆</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white h-100 shadow-sm border-0 rounded-4 hover-lift" style="background: linear-gradient(135deg, #0284c7, #0ea5e9);">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-white-50 small fw-bold text-uppercase mb-2 tracking-wider">Transactions</div>
                        <div class="display-6 fw-bold mb-0">@ViewBag.TransactionsCount</div>
                    </div>
                    <div class="fs-1 opacity-50 bg-white bg-opacity-10 rounded-circle p-3 d-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">🧾</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- BUDGET ALERTS -->
@if (ViewBag.BudgetAlerts != null && ((IEnumerable<dynamic>)ViewBag.BudgetAlerts).Any())
{
    <div class="alert alert-danger shadow-sm border-0 rounded-4 d-flex align-items-center mb-4 p-4" role="alert">
        <div class="bg-danger bg-opacity-10 rounded-circle p-3 me-4 d-flex align-items-center justify-content-center">
            <i class="fs-2">⚠️</i>
        </div>
        <div>
            <h5 class="alert-heading mb-2 fw-bold text-danger">Budget Exceeded!</h5>
            <p class="mb-0 text-danger opacity-75">
                You have exceeded your monthly budget for: 
                @foreach(var alert in ViewBag.BudgetAlerts)
                {
                    <span class="me-2 fw-semibold text-dark">
                        @alert.CategoryName
                        <span class="text-muted fw-normal">(<span class="text-decoration-underline text-danger fw-bold">@alert.TotalFormatted</span> of @alert.BudgetFormatted),</span>
                    </span>
                }
            </p>
        </div>
    </div>
}

<!-- CHARTS & ANALYTICS ROW -->
<div class="row g-4 mb-4">
    <!-- Categories Doughnut Chart -->
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 rounded-4 h-100 hover-lift">
            <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0 text-center">
                <h6 class="mb-0 fw-bold text-uppercase text-muted tracking-wider">Breakdown for @months[(ViewBag.SelectedMonth) - 1] @ViewBag.SelectedYear</h6>
            </div>
            <div class="card-body p-4">
                @if (ViewBag.Labels != null && ViewBag.Labels.Length > 0)
                {
                    <div style="position: relative; height:300px; width:100%">
                        <canvas id="expenseChart"></canvas>
                    </div>
                }
                else
                {
                    <div class="text-center border-0 p-4 rounded-4 h-100 d-flex flex-column justify-content-center align-items-center mt-2" style="background-color: var(--background-color) !important;">
                        <i class="fs-1 d-block mb-3 opacity-50">📊</i>
                        <span class="fw-semibold text-secondary" style="color: var(--text-color) !important;">No expenses for this month.</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Category Analytics / Budgets -->
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 rounded-4 h-100 hover-lift">
            <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0">
                <h6 class="mb-0 fw-bold text-uppercase text-muted tracking-wider">Budget Tracking</h6>
            </div>
            <div class="card-body p-4">
                <ul class="nav nav-pills nav-fill mb-4 bg-light rounded-pill p-1" id="analyticsTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active rounded-pill fw-semibold py-2" id="categories-tab" data-bs-toggle="tab" data-bs-target="#categories" type="button" role="tab" aria-controls="categories" aria-selected="true">Category</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link rounded-pill fw-semibold py-2" id="groups-tab" data-bs-toggle="tab" data-bs-target="#groups" type="button" role="tab" aria-controls="groups" aria-selected="false">Group</button>
                    </li>
                </ul>

                <div class="tab-content" id="analyticsTabContent">
                    <div class="tab-pane fade show active analytics-container" id="categories" role="tabpanel" aria-labelledby="categories-tab" style="max-height: 270px; overflow-y: auto; padding-right: 10px;">
                        @if (ViewBag.CategoryAnalytics != null)
                        {
                            foreach (var item in ViewBag.CategoryAnalytics)
                            {
                                var hasBudget = item.Budget != null && item.Budget > 0;
                                var percent = hasBudget ? (double)(item.Total / item.Budget) * 100 : 0;
                                var isOverBudget = percent > 100;
                                var barColor = isOverBudget ? "bg-danger" : "bg-success";
                                var displayPercent = percent > 100 ? 100 : percent;

                                <div class="mb-4">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <div class="d-flex align-items-center gap-2">
                                            <div style="width: 10px; height: 10px; background-color: @item.CategoryColor; border-radius: 50%;"></div>
                                            <span class="fw-semibold text-dark" style="color: var(--text-color) !important;">@item.CategoryName</span>
                                        </div>
                                        <span class="fw-bold text-dark" style="color: var(--text-color) !important;">@item.Total.ToString("C")</span>
                                    </div>
                                    @if (hasBudget)
                                    {
                                        <div class="progress bg-light rounded-pill" style="height: 6px;">
                                            <div class="progress-bar @barColor rounded-pill" role="progressbar" style="width: @displayPercent%" aria-valuenow="@displayPercent" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                        <div class="d-flex justify-content-between mt-2">
                                            <small class="text-muted fw-medium">Budget: @item.Budget?.ToString("C")</small>
                                            @if (isOverBudget)
                                            {
                                                <small class="text-danger fw-bold">Over Budget</small>
                                            }
                                            else
                                            {
                                                <small class="text-success fw-medium">@((100 - percent).ToString("0"))% left</small>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <small class="text-muted fst-italic">No budget set</small>
                                    }
                                </div>
                            }
                        }
                    </div>
                    
                    <div class="tab-pane fade analytics-container" id="groups" role="tabpanel" aria-labelledby="groups-tab" style="max-height: 270px; overflow-y: auto; padding-right: 10px;">
                        @if (ViewBag.GroupAnalytics != null)
                        {
                            foreach (var g in ViewBag.GroupAnalytics)
                            {
                                <div class="mb-3 p-3 rounded-4 border-0" style="background-color: var(--background-color) !important;">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="fw-semibold text-secondary" style="color: var(--text-color) !important;">@g.GroupName</span>
                                        <span class="fw-bold fs-5 text-dark" style="color: var(--text-color) !important;">@g.Total.ToString("C")</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- TRENDS CHART ROW (FULL WIDTH) -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card shadow-sm border-0 rounded-4 hover-lift">
            <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0 ps-4">
                <h6 class="mb-0 fw-bold text-uppercase text-muted tracking-wider">Trends in @ViewBag.SelectedYear</h6>
            </div>
            <div class="card-body p-4">
                <div style="position: relative; height:320px; width:100%">
                    <canvas id="trendChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Category Doughnut Chart (for selected month)
            var labels = @Html.Raw(Json.Serialize(ViewBag.Labels));
            var data = @Html.Raw(Json.Serialize(ViewBag.Data));
            var bgColors = @Html.Raw(Json.Serialize(ViewBag.Colors));

            if (labels && labels.length > 0) {
                var ctxDoughnut = document.getElementById('expenseChart').getContext('2d');
                Chart.defaults.font.family = "'Inter', sans-serif";
                Chart.defaults.color = '#64748b';
                new Chart(ctxDoughnut, {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Expenses (₱)',
                            data: data,
                            backgroundColor: bgColors,
                            borderWidth: 0,
                            hoverOffset: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        layout: { padding: 10 },
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: { padding: 20, usePointStyle: true, pointStyle: 'circle' }
                            },
                            tooltip: {
                                backgroundColor: 'rgba(15, 23, 42, 0.9)', padding: 12, cornerRadius: 8,
                                callbacks: {
                                    label: function(context) {
                                        let v = context.parsed;
                                        return context.label + ': ' + new Intl.NumberFormat('en-PH', { style: 'currency', currency: 'PHP' }).format(v);
                                    }
                                }
                            }
                        },
                        cutout: '75%'
                    }
                });
            }

            // Line Chart (Monthly Trends by Category)
            var trendDatasets = @Html.Raw(Json.Serialize(ViewBag.TrendDatasets));
            var monthLabels = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
            
            // Adapt "Total Spending" line color to current theme
            const isDark = document.body.getAttribute('data-theme') === 'dark';
            const totalLineColor = isDark ? '#ffffff' : '#212529';
            trendDatasets.forEach(dataset => {
                if (dataset.label === 'Total Spending') {
                    dataset.borderColor = totalLineColor;
                    dataset.backgroundColor = totalLineColor;
                }
            });

            var ctxTrend = document.getElementById('trendChart').getContext('2d');
            var trendChart = new Chart(ctxTrend, {
                type: 'line',
                data: {
                    labels: monthLabels,
                    datasets: trendDatasets
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false,
                    },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(15, 23, 42, 0.9)', padding: 12, cornerRadius: 8,
                            callbacks: {
                                label: function(context) {
                                    return context.dataset.label + ': ' + new Intl.NumberFormat('en-PH', { style: 'currency', currency: 'PHP' }).format(context.parsed.y);
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            border: { display: false },
                            grid: { color: '#f1f5f9', drawBorder: false },
                            ticks: {
                                callback: function(value) {
                                    return '₱' + value;
                                },
                                font: { size: 10 }
                            }
                        },
                        x: {
                            border: { display: false },
                            grid: { display: false },
                            ticks: { font: { size: 10 } }
                        }
                    }
                }
            });

            // Listen for theme toggle to update the chart color dynamically
            const themeBtn = document.getElementById('themeToggleBtn');
            if (themeBtn) {
                themeBtn.addEventListener('click', function() {
                    setTimeout(() => {
                        const newIsDark = document.body.getAttribute('data-theme') === 'dark';
                        const newColor = newIsDark ? '#ffffff' : '#212529';
                        
                        trendChart.data.datasets.forEach(dataset => {
                            if (dataset.label === 'Total Spending') {
                                dataset.borderColor = newColor;
                                dataset.backgroundColor = newColor;
                            }
                        });
                        trendChart.update();
                    }, 50);
                });
            }
        });
    </script>
}
