@model IEnumerable<ExpenseTracker.Models.Category>

@{
    ViewData["Title"] = "Categories Setup";
}

<div class="row align-items-center mb-4 mt-3">
    <div class="col-md-6">
        <h2 class="fw-bold text-primary mb-0">Categories</h2>
        <p class="text-muted">Manage your spending buckets, colors, and budgets.</p>
    </div>
    <div class="col-md-6 text-md-end">
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
            <i class="me-1">➕</i> Create Category
        </a>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4 mb-5 hover-lift">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Group</th>
                        <th>Color</th>
                        <th>@Html.DisplayNameFor(model => model.Name)</th>
                        <th>Budget</th>
                        <th>Order</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                    <tr>
                        <td class="ps-4">
                            <span class="badge bg-secondary opacity-75 rounded-pill px-2 py-1">@(item.Group ?? "None")</span>
                        </td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div style="width: 24px; height: 24px; background-color: @(item.Color ?? "#ccc"); border-radius: 50%; box-shadow: 0 0 0 1px rgba(0,0,0,0.1);" class="me-2"></div>
                                <small class="text-muted font-monospace">@item.Color</small>
                            </div>
                        </td>
                        <td class="fw-bold fs-6">@item.Name</td>
                        <td class="fw-medium text-dark">
                            @(item.MonthlyBudget.HasValue ? item.MonthlyBudget.Value.ToString("C") : "No Limit")
                        </td>
                        <td class="text-secondary fw-semibold">@item.DisplayOrder</td>
                        <td class="text-end pe-4">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary fw-medium px-3">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary fw-medium px-3">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger fw-medium px-3">Delete</a>
                            </div>
                        </td>
                    </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
