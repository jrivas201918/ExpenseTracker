@model ExpenseTracker.Models.Expense
@{
    ViewData["Title"] = "Add Expense";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-lg border-0 rounded-4 hover-lift">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <h3 class="fw-bold text-primary mb-2">Create Expense</h3>
                    <p class="text-muted">Track a new transaction</p>
                </div>

                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <div class="form-floating mb-3">
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId" aria-label="Category">
                            <option value="">-- Select Category --</option>
                        </select>
                        <label asp-for="CategoryId">Category</label>
                        <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Amount" class="form-control" placeholder="0.00" type="number" step="0.01" />
                        <label asp-for="Amount">Amount</label>
                        <span asp-validation-for="Amount" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Date" class="form-control" type="date" />
                        <label asp-for="Date">Date</label>
                        <span asp-validation-for="Date" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Notes" class="form-control" placeholder="Optional notes" />
                        <label asp-for="Notes">Notes (Optional)</label>
                        <span asp-validation-for="Notes" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm">Save Expense</button>
                        <a asp-action="Index" class="btn btn-danger fw-bold mt-2">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
