@model IEnumerable<ExpenseTracker.Models.Expense>
@{
    ViewData["Title"] = "Expenses";
}

<div class="row align-items-center mb-4 mt-3">
    <div class="col-md-6">
        <h2 class="fw-bold text-primary mb-0">Expenses</h2>
        <p class="text-muted">Manage your transactions</p>
    </div>
    <div class="col-md-6 text-md-end">
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
            <i class="me-1">➕</i> Add Expense
        </a>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4 mb-5 hover-lift">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">@Html.DisplayNameFor(model => model.Date)</th>
                        <th>@Html.DisplayNameFor(model => model.Category)</th>
                        <th>@Html.DisplayNameFor(model => model.Notes)</th>
                        <th>@Html.DisplayNameFor(model => model.Amount)</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
            @foreach (var item in Model) {
                    <tr>
                        <td class="ps-4 fw-medium text-secondary">@item.Date.ToShortDateString()</td>
                        <td>
                            @{
                                var bgColor = item.Category?.Color ?? "#6c757d";
                            }
                            <span class="badge rounded-pill px-3 py-2 fw-semibold" style="background-color: @bgColor; color: #fff; text-shadow: 0 1px 2px rgba(0,0,0,0.2);">
                                @Html.DisplayFor(modelItem => item.Category.Name)
                            </span>
                        </td>
                        <td class="text-muted text-truncate" style="max-width: 200px;">@Html.DisplayFor(modelItem => item.Notes)</td>
                        <td class="fw-bold text-dark fs-6">@item.Amount.ToString("C")</td>
                        <td class="text-end pe-4">
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary fw-medium px-3">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary fw-medium px-3">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger fw-medium px-3">Delete</a>
                            </div>
                        </td>
                    </tr>
            }
                </tbody>
            </table>
        </div>
    </div>
</div>
